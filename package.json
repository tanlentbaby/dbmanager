{
  "name": "dbmanager",
  "version": "0.4.0-dev",
  "description": "Interactive database management CLI tool built with Ink + React + TypeScript",
  "main": "dist/main.js",
  "bin": {
    "dbmanager": "./dist/main.js",
    "dbm": "./dist/main.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "start": "node dist/main.js",
    "clean": "rm -rf dist",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "database",
    "cli",
    "mysql",
    "postgresql",
    "sqlite",
    "admin",
    "ink",
    "react"
  ],
  "author": "DBManager Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "conf": "^13.1.0",
    "ink": "^5.2.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "keytar": "^7.9.0",
    "mysql2": "^3.14.0",
    "pg": "^8.14.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.11.11",
    "@types/react": "^18.3.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
